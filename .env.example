# App DB (postgres)
POSTGRES_USER=cc
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb
POSTGRES_PORT=5433

# Metrics DB (timescaledb)
TIMESCALE_USER=cc
TIMESCALE_PASSWORD=changeme
TIMESCALE_DB=metricsdb
TIMESCALE_PORT=5434

# Redis
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# Mosquitto
MQTT_PORT=1883
MQTT_DEVICE_SERVICE_USERNAME=device-service
MQTT_DEVICE_USERNAME=device
# After changing any MQTT passwords, regenerate the password file:
# make mosquitto-passwd
MQTT_DEVICE_SERVICE_PASSWORD=changeme
MQTT_DEVICE_PASSWORD=changeme

# Device service tuning
# Readings older than this are excluded from averaging and control decisions.
# Should be at least 2x the simulator/device publish interval to tolerate one missed reading.
CONTROL_STALE_THRESHOLD_SECONDS=90

# How often the control loop evaluates each room and publishes actuator commands.
# Lowering this increases responsiveness but adds MQTT and TimescaleDB write load.
CONTROL_TICK_INTERVAL_SECONDS=30

# How often each room's cache is reloaded from the database as a safety net for missed stream events.
# Does not need to be low — stream events handle real-time invalidation.
CONTROL_CACHE_REFRESH_MINUTES=5

# Set to "info" for key event logging or "verbose" for full cache and tick detail. Leave empty to disable.
DEVICE_DEBUG=
# Enable independently of DEVICE_DEBUG level — both must be active for output.
DEVICE_TRACE_INGESTION=false
DEVICE_TRACE_TICK=false

# JWT
JWT_SECRET=changeme-replace-with-32-plus-chars-in-prod
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Services
API_PORT=8080

# Simulator
SIMULATOR_EMAIL=simulator@local.dev
SIMULATOR_PASSWORD=changeme